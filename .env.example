VITE_API_BASE_URL=https://meetingmate-backend.onrender.com
VITE_MAX_UPLOAD_MB=250
VITE_GROQ_API_KEY=your_groq_api_key
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
# Optional: only needed if your EmailJS account requires an access token
# VITE_EMAILJS_ACCESS_TOKEN=your_emailjs_access_token

# Backend upload service
GROQ_API_KEY=your_server_side_groq_api_key
GEMINI_API_KEY=your_gemini_api_key
MAX_UPLOAD_MB=250
MAX_FORM_MEMORY_MB=8
MAX_FORM_PARTS=8
STORAGE_DIR=backend/storage
UPLOAD_STORAGE_DIR=backend/storage/uploads
JOB_STORAGE_DIR=backend/storage/jobs
NORMALIZED_STORAGE_DIR=backend/storage/normalized
CHUNK_DURATION_SECONDS=600
JOB_QUEUE_WORKERS=2
TRANSCRIPTION_WORKERS=3
CHUNK_TRANSCRIPTION_RETRIES=3
SUMMARY_RETRIES=2
SUMMARY_DIRECT_CHAR_LIMIT=18000
KEEP_SOURCE_UPLOADS=false
KEEP_CHUNK_ARTIFACTS=false
UPLOAD_TIMEOUT_SECONDS=3600
TRANSCRIPTION_TIMEOUT_SECONDS=3600
SUMMARY_TIMEOUT_SECONDS=300
TRANSCRIPTION_MODEL=whisper-large-v3
SUMMARY_MODEL=llama-3.1-8b-instant
CORS_ORIGINS=*
GUNICORN_WORKERS=1
GUNICORN_THREADS=8

# EmailJS template variables expected by the auth flow:
# {{to_email}}
# {{otp_code}}
# {{otp_purpose}}
# {{otp_expiry_minutes}}
# {{app_name}}

# Export email delivery over SMTP
# Legacy SMTP_* variable names are also supported by the backend.
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password
MAIL_FROM=your@email.com
MAIL_FROM_NAME=MeetingMate AI
MAIL_USE_TLS=true
MAIL_MAX_ATTACHMENT_MB=10
